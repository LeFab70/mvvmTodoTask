<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="TaskManager.Views.AddTaskPage"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    Title="Ajouter">

    <ScrollView>
        <VerticalStackLayout Padding="16" Spacing="14">
            <Border StrokeThickness="0" BackgroundColor="{AppThemeBinding Light=#F8FAFC, Dark=#0B1220}">
                <VerticalStackLayout Padding="16" Spacing="12">
                    <Label Text="Nouvelle tâche" FontAttributes="Bold" FontSize="18" />

                    <Border
                        Stroke="{AppThemeBinding Light=#CBD5E1, Dark=#334155}"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0F172A}"
                        Padding="12,10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Entry
                            Placeholder="Titre"
                            Text="{Binding Titre, Mode=TwoWay}"
                            ReturnCommand="{Binding AjouterCommand}" />
                    </Border>

                    <Border
                        Stroke="{AppThemeBinding Light=#CBD5E1, Dark=#334155}"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0F172A}"
                        Padding="12,2">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Picker
                            Title="Catégorie"
                            ItemsSource="{Binding Categories}"
                            SelectedItem="{Binding Categorie, Mode=TwoWay}" />
                    </Border>

                    <Border
                        Stroke="{AppThemeBinding Light=#CBD5E1, Dark=#334155}"
                        StrokeThickness="1"
                        BackgroundColor="{AppThemeBinding Light=#FFFFFF, Dark=#0F172A}"
                        Padding="12,10">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="12" />
                        </Border.StrokeShape>
                        <Editor
                            Placeholder="Description"
                            AutoSize="TextChanges"
                            MinimumHeightRequest="140"
                            Text="{Binding Description, Mode=TwoWay}" />
                    </Border>

                    <Button Text="Ajouter la tâche" Command="{Binding AjouterCommand}" />
                </VerticalStackLayout>
            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>

